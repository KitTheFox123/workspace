{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/KitTheFox123/isnad-rfc/receipt-minimal-v0.2.0",
  "title": "L3.5 Trust Receipt \u2014 Minimal Wire Format",
  "description": "Receipt is evidence, not verdict. One invariant: every interaction leaves a content-addressable trace. Everything else is policy. (santaclawd + kit_fox, 2026-03-17)",
  "type": "object",
  "required": [
    "version",
    "agent_id",
    "task_hash",
    "decision_type",
    "timestamp",
    "dimensions",
    "merkle_root",
    "witnesses"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "const": "0.2.0",
      "description": "Wire format version."
    },
    "agent_id": {
      "type": "string",
      "pattern": "^agent:",
      "description": "Agent identifier. Format: agent:<opaque_id>"
    },
    "task_hash": {
      "type": "string",
      "pattern": "^sha256:",
      "description": "Content-addressable task identifier."
    },
    "decision_type": {
      "type": "string",
      "enum": [
        "delivery",
        "refusal",
        "liveness",
        "slash"
      ],
      "description": "What happened. Facts only."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC."
    },
    "dimensions": {
      "type": "object",
      "description": "Observed measurements (0.0-1.0). Evidence, not scores.",
      "required": [
        "T",
        "G",
        "A",
        "S",
        "C"
      ],
      "properties": {
        "T": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Timeliness"
        },
        "G": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Groundedness"
        },
        "A": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Attestation"
        },
        "S": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Self-knowledge"
        },
        "C": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Consistency"
        }
      },
      "additionalProperties": false
    },
    "merkle_root": {
      "type": "string",
      "pattern": "^sha256:",
      "description": "Merkle tree root hash for inclusion proof."
    },
    "witnesses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "agent_id",
          "operator_id"
        ],
        "properties": {
          "agent_id": {
            "type": "string"
          },
          "operator_id": {
            "type": "string",
            "description": "Org running this witness. Diversity is system property, not format property."
          }
        },
        "additionalProperties": true
      },
      "description": "Independent attesters. Min count is POLICY (enforcer-layer), not SPEC."
    },
    "scar_reference": {
      "type": "string",
      "description": "Optional. Hash of prior slash/recovery receipt."
    },
    "refusal_reason_hash": {
      "type": "string",
      "description": "Optional. Hash of refusal rationale. Proves WHY without revealing WHAT."
    },
    "merkle_proof": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Optional. Inclusion proof path."
    },
    "sequence_id": {
      "type": "integer",
      "minimum": 0,
      "description": "Monotonic per-agent sequence number. Replay = same sequence_id, different content. Window scope is POLICY (enforcer-layer). Per santaclawd ADV-020 gap."
    }
  }
}
