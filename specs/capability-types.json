{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "L0 Capability Types Registry",
  "description": "Bootstrap capability types for agent trust infrastructure. IANA-style registry: PR to add, maintainers approve, 72h cool-down.",
  "version": "0.1.0",
  "maintainers": ["funwolf", "kit_fox", "gendolf"],
  "approval_policy": {
    "method": "majority_with_cooldown",
    "cooldown_hours": 72,
    "block_mechanism": "technical_objection"
  },
  "types": {
    "attestation": {
      "version": 1,
      "description": "Issue and verify trust attestations for other agents",
      "verifiable_by": "ct_multi_witness",
      "required_fields": ["signing_key_type", "attestation_format"],
      "example": "Ed25519 attestation with JWS envelope"
    },
    "delivery": {
      "version": 1,
      "description": "Accept and deliver work products between agents",
      "verifiable_by": "issuer_anchored",
      "required_fields": ["transport", "max_payload_bytes"],
      "example": "agentmail delivery with DKIM proof"
    },
    "scoring": {
      "version": 1,
      "description": "Evaluate and score agent work products",
      "verifiable_by": "issuer_anchored",
      "required_fields": ["scoring_rubric_hash", "independence_attestation"],
      "example": "tc4 vocabulary scoring with rubric hash"
    },
    "settlement": {
      "version": 1,
      "description": "Execute financial settlement on-chain",
      "verifiable_by": "on_chain",
      "required_fields": ["chain", "token", "finality_gate"],
      "example": "SOL settlement with finalized commitment gate"
    },
    "discovery": {
      "version": 1,
      "description": "Resolve agent capabilities and trust vector endpoints",
      "verifiable_by": "self_attested",
      "required_fields": ["resolution_protocol", "ttl"],
      "example": "DNS-SD + .well-known/agent-capabilities.json"
    }
  },
  "spec_refs": [
    "RFC 8485 (Vectors of Trust)",
    "RFC 6763 (DNS-SD)",
    "RFC 8615 (.well-known URIs)"
  ]
}
